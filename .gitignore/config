[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/shabina29/appium-bdd-automation-framework.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[branch "feature/reporting-config"]
	remote = origin
	merge = refs/heads/feature/reporting-config
[branch "feature/jenkins-fix"]
	remote = origin
	merge = refs/heads/feature/jenkins-fix
